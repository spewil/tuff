---
import type { Product } from "../data/products";
import { url } from "../lib/url";

interface Props {
  product: Product;
}

const { product } = Astro.props;

const statusLabel: Record<Product["status"], string> = {
  preorder: "Pre-order",
  available: "In Stock",
  soldout: "Sold Out",
  "coming-soon": "Soon™",
};
const statusClass =
  product.status === "preorder" ? "preorder" : product.status === "soldout" ? "soldout" : "";
---

<a href={url(`/product/${product.slug}`)} class="card window aero">
  <div class="title-bar">
    <span class="title-bar-text comic">{product.name}</span>
    <div class="title-bar-controls">
      <button aria-label="Open" tabindex="-1">□</button>
    </div>
  </div>
  <div class="window-body">
    <div class="thumb">
      <img src={url(product.images[0])} alt={product.name} loading="lazy" />
      <span class={`tag ${statusClass}`}>{statusLabel[product.status]}</span>
    </div>
    <p class="blurb comic">{product.blurb}</p>
    <div class="row">
      <span class="price comic">{product.price}</span>
      <span class="btn-aero hot open">OPEN ►</span>
    </div>
  </div>

  <style>
    .card {
      display: block;
      color: inherit;
      text-decoration: none;
      transition: transform 0.12s ease, filter 0.12s ease;
    }
    .card:hover {
      transform: translateY(-4px) rotate(-0.5deg);
      filter: brightness(1.03);
    }
    .thumb {
      position: relative;
      aspect-ratio: 4 / 5;
      overflow: hidden;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.7);
      box-shadow: inset 0 2px 8px rgba(0, 60, 120, 0.25);
    }
    .thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .thumb .tag {
      position: absolute;
      top: 8px;
      left: 8px;
    }
    .blurb {
      margin: 12px 2px 14px;
      font-size: 0.95rem;
      color: #06346b;
      min-height: 2.4em;
    }
    .row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }
    .price {
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--navy);
      text-shadow: 2px 2px 0 #fff, 3px 3px 0 var(--hotpink);
    }
    .open {
      font-size: 13px;
      padding: 9px 16px;
    }
  </style>
</a>
