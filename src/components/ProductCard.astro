---
import type { Product } from "../data/products";

interface Props {
  product: Product;
}

const { product } = Astro.props;

const statusLabel: Record<Product["status"], string> = {
  preorder: "Pre-order",
  available: "Available",
  soldout: "Sold out",
  "coming-soon": "Coming soon",
};
---

<a href={`/product/${product.slug}`} class="card">
  <div class="img">
    <img src={product.images[0]} alt={product.name} loading="lazy" />
    <span class={`tag ${product.status === "preorder" ? "preorder" : product.status === "soldout" ? "soldout" : ""}`}>
      {statusLabel[product.status]}
    </span>
  </div>
  <div class="meta">
    <h3>{product.name}</h3>
    <p class="blurb">{product.blurb}</p>
    <span class="price">{product.price}</span>
  </div>
</a>

<style>
  .card {
    display: block;
    border: 1px solid var(--line);
    transition: border-color 0.15s ease;
  }
  .card:hover {
    border-color: var(--accent);
  }
  .img {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #111;
  }
  .img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .img .tag {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: rgba(10, 10, 10, 0.8);
  }
  .meta {
    padding: 1rem;
  }
  .meta h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }
  .blurb {
    color: var(--muted);
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }
  .price {
    font-weight: 700;
    font-size: 0.95rem;
  }
</style>
