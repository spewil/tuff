---
import type { Product } from "../data/products";
import { url } from "../lib/url";

interface Props {
  product: Product;
  index: number;
}

const { product, index } = Astro.props;
const soldout = product.status === "soldout";
const tilt = index % 2 === 0 ? "tilt-l" : "tilt-r";
---

<a
  href={url(`/product/${product.slug}`)}
  class={`item ${soldout ? "is-soldout" : ""}`}
  aria-label={product.name}
>
  <figure class={`media ${tilt}`} data-tilt>
    <img src={url(product.images[0])} alt={product.name} loading="lazy" />
    {soldout && <span class="soldout-banner">Sold out</span>}
  </figure>
</a>

<style>
  .item {
    display: block;
    width: min(440px, 82vw);
    margin: clamp(2.5rem, 7vw, 5.5rem) auto;
  }
  .media {
    aspect-ratio: 4 / 5;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  .media img { width: 100%; height: 100%; object-fit: cover; }
  .item:not(.is-soldout):hover .media {
    transform: rotate(0deg) scale(1.03);
    box-shadow: 0 20px 44px rgba(0, 70, 140, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }
</style>
