---
import Layout from "../layouts/Layout.astro";
import { url } from "../lib/url";

const photos = ["The floor", "Quality control", "Embroidery", "Lunch"];
---

<Layout title="Factory — TUFF">
  <section class="f-hero wrap">
    <img class="cherub float" style="--rot:-4deg" src={url("/collage/angel.jpg")} alt="" />
    <div>
      <p class="eyebrow">Made in China · with people we know</p>
      <h1 class="chrome-text">FACTORY</h1>
    </div>
  </section>

  <section class="photos wrap">
    {photos.map((caption) => (
      <figure class="pending">
        <div class="media box"><span>Coming soon</span></div>
        <figcaption class="serif italic">{caption}</figcaption>
      </figure>
    ))}
  </section>

  <div class="tail wrap">
    <a href={url("/")} class="minilink">&larr; home</a>
    <span class="sparkle cyan" style="font-size:22px;"></span>
    <a href={url("/shop")} class="minilink">shop &rarr;</a>
  </div>
</Layout>

<style>
  .f-hero {
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 3rem);
    min-height: 50vh;
    flex-wrap: wrap;
  }
  .f-hero img { width: clamp(160px, 28vw, 280px); }
  .f-hero h1 { font-size: clamp(2.8rem, 12vw, 8rem); }

  .photos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
  }
  .pending { margin: 0; }
  .box {
    aspect-ratio: 4 / 3;
    display: grid;
    place-content: center;
    color: var(--ink-soft);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .pending figcaption {
    font-style: italic;
    color: var(--ink-soft);
    margin-top: 0.5rem;
  }
  .tail {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 3rem 0 1rem;
  }
</style>
