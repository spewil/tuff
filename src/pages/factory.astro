---
import Layout from "../layouts/Layout.astro";
import { url } from "../lib/url";

const photos = ["The floor", "Quality control", "Embroidery", "Lunch"];
---

<Layout title="Factory — TUFF">
  <section class="f-hero wrap">
    <img class="sticker float" style="top:8%; left:5%; width:clamp(64px,8vw,120px);" src={url("/stickers/chrome-blob.svg")} alt="" />
    <img class="sticker float slow" style="bottom:10%; right:5%; width:clamp(60px,8vw,116px);" src={url("/stickers/chrome-star.svg")} alt="" />
    <span class="sparkle lime sticker" style="top:22%; right:14%; font-size:30px;"></span>
    <div class="f-head">
      <p class="eyebrow">// made in China &mdash; with people we know</p>
      <h1 class="chrome-text">FACTORY</h1>
    </div>
  </section>

  <section class="photos wrap">
    {photos.map((caption) => (
      <figure class="pending">
        <div class="media box"><span>Coming soon</span></div>
        <figcaption class="mono cap">{caption}</figcaption>
      </figure>
    ))}
  </section>

  <div class="tail wrap">
    <a href={url("/")} class="minilink">&larr; home</a>
    <span class="sparkle cyan" style="font-size:22px;"></span>
    <a href={url("/shop")} class="minilink">shop &rarr;</a>
  </div>
</Layout>

<style>
  .f-hero {
    position: relative;
    min-height: 58vh;
    display: grid;
    place-items: center;
    text-align: center;
    overflow: hidden;
  }
  .f-head { position: relative; z-index: 2; }
  .f-hero .eyebrow { margin-bottom: 0.4rem; }
  .f-hero h1 { font-size: clamp(2.8rem, 14vw, 8rem); }

  .photos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
  }
  .pending { margin: 0; }
  .box {
    aspect-ratio: 4 / 3;
    display: grid;
    place-content: center;
    color: var(--ink-soft);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .pending .cap {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-top: 0.6rem;
  }
  .tail {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 3rem 0 1rem;
  }
</style>
