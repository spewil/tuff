---
import Layout from "../../layouts/Layout.astro";
import type { Product } from "../../data/products";
import { products, getProduct } from "../../data/products";
import { url } from "../../lib/url";

export function getStaticPaths() {
  return products.map((product) => ({ params: { slug: product.slug } }));
}

const { slug } = Astro.params;
const product = getProduct(slug!)!;

const soldout = product.status === "soldout";
const comingSoon = product.status === "coming-soon";
const buyable = product.status === "preorder" || product.status === "available";
const isPreorder = product.status === "preorder";
const ctaLabel = isPreorder ? "Pre-order" : "Add to bag";

const statusText: Record<Product["status"], string> = {
  preorder: "Pre-order",
  available: "Available",
  soldout: "Sold out",
  "coming-soon": "Coming soon",
};
const statusClass = isPreorder ? "preorder" : soldout ? "soldout" : "soon";
---

<Layout title={`${product.name} — TUFF`} description={product.blurb}>
  <section class="detail wrap">
    <a href={url("/shop")} class="back">&larr; Back to shop</a>

    <div class="cols">
      <div class={`gallery ${soldout ? "is-soldout" : ""}`}>
        {product.images.map((src) => (
          <figure class="media" data-tilt>
            <img src={url(src)} alt={product.name} />
            {soldout && <span class="soldout-banner">Sold out</span>}
          </figure>
        ))}
      </div>

      <div class="info">
        <span class={`tag ${statusClass}`}>{statusText[product.status]}</span>
        <h1 class="name">{product.name}</h1>
        <p class="price mono">{product.price}</p>

        {isPreorder && product.shipEstimate && (
          <p class="ship mono">{product.shipEstimate} · charged today</p>
        )}

        {buyable && (
          <div class="sizes">
            <p class="eyebrow">Size</p>
            <div class="size-row">
              {product.sizes.map((size) => {
                const ok = !size.soldOut && size.stripeLink !== "";
                return (
                  <button class="size" data-link={size.stripeLink} disabled={!ok} aria-disabled={!ok}>
                    {size.label}
                  </button>
                );
              })}
            </div>
          </div>
        )}

        {buyable ? (
          <a id="checkout" class="btn buy is-disabled" href="#" aria-disabled="true">{ctaLabel}</a>
        ) : (
          <p class="unavailable mono">
            {soldout ? "This piece is sold out. It will not be made again." : "Not out yet. Soon."}
          </p>
        )}

        <div class="desc">
          {product.description.map((para) => <p>{para}</p>)}
        </div>
      </div>
    </div>
  </section>

  <style>
    .detail { padding-top: 2rem; }
    .back {
      display: inline-block;
      font-size: 0.82rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-soft);
      margin-bottom: 1.5rem;
    }
    .back:hover { color: var(--ink); }
    .cols {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: clamp(1.5rem, 5vw, 4rem);
      align-items: start;
    }
    .media {
      position: relative;
      margin: 0 0 1rem;
      aspect-ratio: 4 / 5;
      overflow: hidden;
      background: #0c0f13;
    }
    .media img { width: 100%; height: 100%; object-fit: cover; }
    .gallery.is-soldout .media img { filter: grayscale(1) brightness(0.55); }

    .info { position: sticky; top: 40px; }
    .info .tag { margin-bottom: 1rem; }
    .name { font-size: clamp(2.2rem, 6vw, 3.6rem); margin-bottom: 0.5rem; }
    .price { font-family: var(--mono); font-weight: 700; font-size: 1.8rem; margin-bottom: 0.4rem; color: var(--cyan); }
    .ship { color: var(--lime); font-size: 0.95rem; margin-bottom: 1.5rem; }

    .sizes { margin: 1.5rem 0; }
    .size-row { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 0.6rem; }
    .size {
      min-width: 3.2rem;
      padding: 0.7rem 1rem;
      font-family: var(--body);
      font-size: 0.95rem;
      background: transparent;
      color: var(--ink);
      border: 1.5px solid var(--ink);
      border-radius: 2px;
      cursor: pointer;
      transition: background 0.15s ease, color 0.15s ease;
    }
    .size:hover:not([disabled]) { background: var(--lime); color: #000; border-color: var(--lime); }
    .size[disabled] {
      border-color: var(--line);
      color: var(--ink-soft);
      text-decoration: line-through;
      cursor: not-allowed;
    }
    .size.selected { background: var(--lime); color: #000; border-color: var(--lime); }

    .buy { width: 100%; justify-content: center; padding: 1.1em; margin-top: 0.5rem; }
    .unavailable { font-size: 1.2rem; color: var(--ink-soft); margin: 1.5rem 0; }

    .desc {
      margin-top: 2.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--line);
      color: var(--ink-soft);
    }
    .desc p { margin-bottom: 1rem; max-width: 50ch; }

    @media (max-width: 760px) {
      .cols { grid-template-columns: 1fr; }
      .info { position: static; }
    }
  </style>

  <script>
    const sizes = document.querySelectorAll<HTMLButtonElement>(".size");
    const checkout = document.getElementById("checkout") as HTMLAnchorElement | null;
    sizes.forEach((s) => {
      s.addEventListener("click", () => {
        if (s.disabled) return;
        sizes.forEach((x) => x.classList.remove("selected"));
        s.classList.add("selected");
        const link = s.dataset.link;
        if (checkout && link) {
          checkout.setAttribute("href", link);
          checkout.classList.remove("is-disabled");
          checkout.setAttribute("aria-disabled", "false");
        }
      });
    });
  </script>
</Layout>
