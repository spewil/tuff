---
import Layout from "../layouts/Layout.astro";
import ShopItem from "../components/ShopItem.astro";
import { products } from "../data/products";
import { url } from "../lib/url";
---

<Layout title="Shop — TUFF">
  <section class="feed">
    <!-- schizo sprite layer: chrome / gel / pixel / doodle -->
    <img class="sticker float" style="top:4%; left:5%; width:clamp(60px,8vw,116px);" src={url("/stickers/chrome-star.svg")} alt="" />
    <img class="sticker float slow" style="top:30%; right:5%; width:clamp(54px,7vw,100px);" src={url("/stickers/pixel-heart.svg")} alt="" />
    <img class="sticker float" style="top:58%; left:4%; width:clamp(58px,8vw,112px); transform:rotate(-10deg);" src={url("/stickers/doodle-star.svg")} alt="" />
    <img class="sticker float slow" style="bottom:11%; right:6%; width:clamp(66px,9vw,132px);" src={url("/stickers/chrome-blob.svg")} alt="" />
    <img class="sticker float" style="top:80%; right:9%; width:clamp(52px,7vw,98px);" src={url("/stickers/gel-star.svg")} alt="" />
    <span class="sparkle lime sticker" style="top:44%; right:9%; font-size:28px;"></span>
    <span class="sparkle magenta sticker" style="top:18%; left:14%; font-size:24px;"></span>

    {products.map((product, i) => <ShopItem product={product} index={i} />)}

    <div class="tail wrap">
      <hr class="divider" />
      <div class="tail-links">
        <a href={url("/")} class="minilink">&larr; home</a>
        <span class="sparkle cyan" style="font-size:22px;"></span>
        <a href={url("/factory")} class="minilink">factory &rarr;</a>
      </div>
    </div>
  </section>

  <style>
    .feed { position: relative; padding: clamp(2rem, 6vw, 4rem) 0 0; overflow: hidden; }
    .tail { margin-top: 2rem; }
    .tail-links {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      padding: 1.6rem 0;
    }
    @media (max-width: 760px) { .feed .sticker { display: none; } }
  </style>
</Layout>
