---
import Layout from "../layouts/Layout.astro";
import { url } from "../lib/url";
---

<Layout>
  <section class="hero">
    <!-- weird floating layer -->
    <img class="cherub float sticker" style="--rot:6deg; top:8%; right:8%; width:clamp(120px,18vw,230px);" src={url("/collage/putto.jpg")} alt="" />
    <img class="cherub float sticker" style="--rot:-7deg; bottom:6%; left:4%; width:clamp(90px,12vw,160px);" src={url("/collage/venus.jpg")} alt="" />
    <span class="orb float sticker" style="top:20%; left:10%; width:84px;"></span>
    <span class="orb float sticker" style="bottom:22%; right:16%; width:54px;"></span>
    <span class="starburst sticker tilt-r" style="top:12%; left:6%;">new<br />s'tuff</span>
    <span class="sparkle pink sticker" style="top:64%; left:24%; font-size:54px;"></span>
    <span class="sparkle cyan sticker" style="top:30%; right:28%; font-size:34px;"></span>

    <div class="hero-core">
      <p class="eyebrow">Limited apparel</p>
      <h1 class="chrome-text title">TUFF</h1>
      <div class="hero-links">
        <a href={url("/shop")} class="btn btn--hot">Shop &rarr;</a>
        <a href={url("/factory")} class="minilink">or see the factory</a>
      </div>
    </div>
  </section>

  <style>
    .hero {
      position: relative;
      min-height: 92vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--pad);
      overflow: hidden;
    }
    .hero-core { position: relative; z-index: 2; text-align: center; }
    .title {
      font-size: clamp(5rem, 22vw, 16rem);
      margin: 0.1em 0 0.5em;
    }
    .hero-links {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
    }
    @media (max-width: 600px) {
      .hero .sticker { opacity: 0.85; }
    }
  </style>
</Layout>
