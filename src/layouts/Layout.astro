---
import "../styles/global.css";
import { url } from "../lib/url";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "TUFF",
  description = "Limited edition apparel drops.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={url("/favicon.svg")} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a href={url("/")} class="logo">TUFF</a>
        <nav>
          <a href={url("/") + "#drops"}>Drops</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <span>TUFF</span>
        <span class="muted">&copy; {new Date().getFullYear()} — All rights reserved.</span>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--line);
        position: sticky;
        top: 0;
        background: rgba(10, 10, 10, 0.85);
        backdrop-filter: blur(8px);
        z-index: 10;
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .logo {
        font-weight: 800;
        font-size: 1.4rem;
        letter-spacing: 0.15em;
      }
      nav a {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--muted);
      }
      nav a:hover {
        color: var(--fg);
      }
      .site-footer {
        border-top: 1px solid var(--line);
        margin-top: 6rem;
        padding: 2rem 0;
      }
      .site-footer .wrap {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        letter-spacing: 0.1em;
      }
      .muted {
        color: var(--muted);
      }
    </style>
  </body>
</html>
